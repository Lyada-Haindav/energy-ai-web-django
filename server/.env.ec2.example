PORT=3000
ALLOWED_ORIGIN=https://your-domain.com
APP_BASE_URL=https://your-domain.com
APP_DATA_DIR=/var/lib/energy-ai

# Provider choice per role: mock | own | python_local | ollama | openai
ROUTER_PROVIDER=own
FAST_PROVIDER=own
DEEP_PROVIDER=own

# Model names for each role
ROUTER_MODEL=energy-router-own-v1
FAST_MODEL=energy-low-own-v1
DEEP_MODEL=energy-high-own-v1

# Shared generation defaults
MAX_TOKENS=700
TEMPERATURE=0.4

# Own local model artifacts for the lightweight local stack
OWN_MODELS_DIR=./model-artifacts/own

# Local Python checkpoint server (only if you really run one on EC2)
PYTHON_LOCAL_BASE_URL=http://127.0.0.1:9001

# Ollama (not recommended on t3.micro unless you know the memory tradeoff)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI-compatible endpoint (optional)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Optional web grounding
ENABLE_WEB_KNOWLEDGE=false

# Auth / email
BREVO_API_KEY=
EMAIL_FROM=your-verified-sender@example.com
EMAIL_FROM_NAME=Energy AI
ADMIN_EMAILS=admin@example.com

# Optional MongoDB; if unset, the app uses APP_DATA_DIR file storage
MONGODB_URI=
MONGODB_DB_NAME=
MONGODB_COLLECTION=appData
MONGODB_DOCUMENT_ID=energy-ai
