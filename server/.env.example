PORT=8787
ALLOWED_ORIGIN=http://localhost:5173

# Provider choice per role: mock | own | python_local | ollama | openai
ROUTER_PROVIDER=mock
FAST_PROVIDER=mock
DEEP_PROVIDER=mock

# Model names for each role
ROUTER_MODEL=energy-router-v1
FAST_MODEL=energy-low-v1
DEEP_MODEL=energy-high-v1

# Shared generation defaults
MAX_TOKENS=700
TEMPERATURE=0.4

# Own local model artifacts (used when provider=own)
OWN_MODELS_DIR=./model-artifacts/own

# Local Python checkpoint server (used when provider=python_local)
PYTHON_LOCAL_BASE_URL=http://127.0.0.1:9001

# Ollama (if used)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI compatible endpoint (if used)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# App/auth/email
APP_BASE_URL=http://localhost:5173
BREVO_API_KEY=
EMAIL_FROM=your-verified-sender@example.com
EMAIL_FROM_NAME=Energy AI

# MongoDB app storage; when MONGODB_URI is set, Mongo is required by default
MONGODB_URI=
MONGODB_DB_NAME=
MONGODB_COLLECTION=appData
MONGODB_DOCUMENT_ID=energy-ai
MONGODB_REQUIRED=true
MONGODB_USERS_COLLECTION=users
MONGODB_SESSIONS_COLLECTION=authSessions
MONGODB_CHATS_COLLECTION=chatSessions
MONGODB_TRAINING_APPROVED_COLLECTION=trainingApproved
MONGODB_TRAINING_CANDIDATE_COLLECTION=trainingCandidates
MONGODB_TRAINING_REJECTED_COLLECTION=trainingRejected
MONGODB_EVALUATION_COLLECTION=evaluationRuns

# Local mirrors for training/evaluation history
EVALUATION_RUNS_PATH=../training/data/local/evaluation_runs.jsonl
